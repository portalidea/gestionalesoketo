# Copia in .env.local e popola con i tuoi valori reali.
# .env.local NON deve essere committato (vedi .gitignore).

# ============================================================
# Supabase
# ============================================================
# Project URL — Supabase → Settings → API
SUPABASE_URL=
# Anon (publishable) key — sicura da esporre al client
SUPABASE_ANON_KEY=
# Service role key — MAI esporre al client; solo lato server
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret — Supabase → Settings → API → JWT Settings
SUPABASE_JWT_SECRET=

# Frontend (Vite richiede prefisso VITE_)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ============================================================
# Database (Postgres / Supabase)
# ============================================================
# Connection string — Supabase → Settings → Database
# Per uso serverless (Vercel) usare la variante pgbouncer port 6543
DATABASE_URL=

# ============================================================
# Auth / ownership
# ============================================================
# Email dell'admin owner (sostituisce OWNER_OPEN_ID legacy)
OWNER_EMAIL=

# ============================================================
# Fatture in Cloud (OAuth2)
# ============================================================
FATTUREINCLOUD_CLIENT_ID=
FATTUREINCLOUD_CLIENT_SECRET=
# In produzione: https://<dominio-vercel>/api/fattureincloud/callback
FATTUREINCLOUD_REDIRECT_URI=
